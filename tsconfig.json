{
	"compilerOptions": {
		"target": "es2024",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"declaration": true,
		"sourceMap": true,
    "rootDir": ".",
		"outDir": "./dist",
	},
  "exclude": ["node_modules", "dist"],
  "include": ["src/**/*"]
}